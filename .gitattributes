# Normalize line endings: LF in the repo for all text, CRLF only where Windows needs it.
* text=auto eol=lf

# Python and config — always LF
*.py    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.md    text eol=lf
*.qss   text eol=lf
*.json  text eol=lf

# Windows-specific scripts — keep CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.iss   text eol=crlf

# Binary assets — never touch
*.ico   binary
*.png   binary
*.jpg   binary
*.xlsx  binary
*.pdf   binary
*.db    binary
